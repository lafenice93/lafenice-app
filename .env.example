# ============================================================
# LAFENICE Onboarding — Environment Variables
# ============================================================
# Copy this file to `.env.local` for local development
# In Vercel, set these in Project Settings → Environment Variables
# ============================================================

# REQUIRED for AI avatar generation.
# Get one at https://platform.openai.com/api-keys
# Stored server-side only — never expose to the browser.
OPENAI_API_KEY=sk-...replace-me...

# OPTIONAL — which OpenAI image model to use for avatar generation.
# Recommended: `gpt-image-1` (supports image-to-image with strong identity preservation)
# Fallback:    `dall-e-3` (text-to-image only)
OPENAI_IMAGE_MODEL=gpt-image-1

# OPTIONAL — image size (1024x1024, 1024x1536, or 1536x1024)
OPENAI_IMAGE_SIZE=1024x1024

# ============================================================
# Future integrations — placeholders for v2
# ============================================================
# ELEVENLABS_API_KEY=         # voice synthesis for EVE companion
# REPLICATE_API_TOKEN=        # alternative face-preserving generation
# BEAUTY_ANALYSIS_API_URL=    # in-house skin/face analysis endpoint
